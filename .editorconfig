# EditorConfig is awesome: https://EditorConfig.org

# top-most EditorConfig file
root = true

[*]
indent_style = space
indent_size = 4
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

[*.md]
indent_size = 1
trim_trailing_whitespace = false

[*.{css,scss,js,json,yml,yaml}]
indent_size = 2

[Dockerfile]
trim_trailing_whitespace = false

[*.php]
indent_size = 4
max_line_length = 120

[*.xml]
indent_size = 2
