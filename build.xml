<?xml version="1.0" encoding="UTF-8"?>
<project name="govbr" default="dev">
    <property name="sourcedir" value="${project.basedir}/govbr" />
    <property name="webdir" value="/var/www/html" />

    <target name="dev" description="Prepare files to development">
        <delete dir="${webdir}/templates/govbr" quiet="true" />
        <delete dir="${webdir}/media/templates/site/govbr" quiet="true" />
        <delete>
            <fileset dir="${webdir}/language">
                <include name="**/*tpl_govbr*.ini" />
            </fileset>
        </delete>

        <copy todir="${webdir}/templates/govbr" overwrite="true">
            <fileset dir="${sourcedir}">
                <include name="*.php" />
                <include name="*.xml" />
                <include name="*.json" />
                <exclude name="language/**" />
                <exclude name="media/**" />
            </fileset>
        </copy>

        <copy todir="${webdir}/language" overwrite="true">
            <fileset dir="${sourcedir}/language">
                <include name="**/*.ini" />
            </fileset>
        </copy>

        <copy todir="${webdir}/media/templates/site/govbr" overwrite="true">
            <fileset dir="${sourcedir}/media">
                <include name="**/*.css" />
                <include name="**/*.js" />
                <include name="**/*.png" />
                <include name="**/*.svg" />
                <include name="**/*.woff2" />
            </fileset>
        </copy>
    </target>
</project>
