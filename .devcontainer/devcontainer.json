{
  "name": "GovBR Theme Dev Environment",
  "dockerComposeFile": "compose.yml",
  "service": "app",
  "workspaceFolder": "/workspaces/${localWorkspaceFolderBasename}",

  "features": {
    "ghcr.io/devcontainers/features/common-utils:2": {
      "installZsh": "true",
      "username": "vscode",
      "userUid": "1000",
      "userGid": "1000",
      "upgradePackages": "true"
    },
    "./local-features/user-config": "latest",
    "./local-features/apache-config": "latest",
    "ghcr.io/devcontainers/features/node:1": "latest"
  },

  "portsAttributes": {
    "8080": {
      "label": "Joomla Web Server",
      "onAutoForward": "silent"
    },
    "8090": {
      "label": "Adminer Web Server",
      "onAutoForward": "silent"
    }
  },

  "forwardPorts": [8080, 8090],

  "customizations": {
    "vscode": {
      "settings": {
        "intelephense.environment.includePaths": ["/var/www/html/"],
        "php.validate.executablePath": "/usr/local/bin/php",
        "php-cs-fixer.executablePath": "${workspaceFolder}/vendor/bin/php-cs-fixer",
        "launch": {
          "version": "0.2.0",
          "configurations": [
            {
              "name": "Listen for Xdebug",
              "type": "php",
              "request": "launch",
              "port": 9003,
              "log": false
            }
          ]
        }
      },
      "extensions": [
        "bmewburn.vscode-intelephense-client",
        "dbaeumer.vscode-eslint",
        "EditorConfig.EditorConfig",
        "esbenp.prettier-vscode",
        "junstyle.php-cs-fixer",
        "ms-azuretools.vscode-containers",
        "redhat.vscode-xml",
        "stylelint.vscode-stylelint",
        "xdebug.php-debug"
      ]
    }
  },

  "postCreateCommand": ".devcontainer/post-create.sh",

  "remoteUser": "vscode"
}
